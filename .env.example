# Variables d'environnement pour le déploiement

# Server Configuration
PORT=3000
NODE_ENV=production

# Discord Webhooks (pour les notifications de réservations)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Database (fichier JSON local)
# Les réservations sont stockées dans reservations.json

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://events.cax-corp.com

# Database
DATABASE_FILE=reservations.json
